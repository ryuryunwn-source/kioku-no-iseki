# 写し身の命名APIキー（GitHubに公開しない。テンプレートのみ追跡）
/[Aa]ssets/[Rr]esources/writeshi_api.txt
/[Aa]ssets/[Rr]esources/writeshi_api.txt.meta

# OS
.DS_Store
Thumbs.db

# Crash reports
sysinfo.txt
*.stackdump

